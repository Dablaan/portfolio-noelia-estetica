---
interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const phoneNumber = "34687432500"; // Assuming Spain country code (+34) for default

const i18n = {
  es: {
    message: 'Hola, estoy interesada en el servicio de...'
  },
  en: {
    message: 'Hello, I am interested in the service of...'
  }
};

const t = i18n[lang];
const encodedMessage = encodeURIComponent(t.message);
const waLink = `https://wa.me/${phoneNumber}?text=${encodedMessage}`;
---

<a 
  href={waLink} 
  target="_blank" 
  rel="noopener noreferrer" 
  class="fixed bottom-6 right-6 z-50 bg-[#25D366] text-white p-4 rounded-full shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-300 flex items-center justify-center group"
  aria-label="Contactar por WhatsApp"
>
  <!-- WhatsApp SVG Icon -->
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    class="w-8 h-8" 
    fill="currentColor" 
    viewBox="0 0 24 24"
  >
    <path d="M11.99 2C6.47 2 2 6.48 2 12c0 1.76.46 3.42 1.25 4.88L2 22l5.25-1.18c1.4.75 3.01 1.18 4.74 1.18 5.52 0 10-4.48 10-10S17.51 2 11.99 2zm5.42 14.28c-.23.64-1.32 1.23-1.83 1.3-.51.08-1.16.27-3.41-.66-2.61-1.07-4.29-3.72-4.43-3.9-.13-.18-1.06-1.41-1.06-2.69 0-1.28.66-1.92.89-2.18.23-.26.51-.31.68-.31.17 0 .34 0 .49.01.16.01.37-.06.57.41.2.48.69 1.69.75 1.82.06.13.11.28.02.46-.08.18-.13.31-.26.46-.13.16-.28.33-.39.46-.13.12-.27.26-.12.52.15.26.68 1.12 1.45 1.81.99.89 1.83 1.19 2.1 1.32.26.13.44.11.61-.08.17-.18.73-.85.92-1.14.2-.29.4-.24.64-.15.24.09 1.54.73 1.81.86.26.13.44.2.5.31.06.11.06.66-.17 1.3z" />
  </svg>
</a>
