---
interface Props {
  lang?: "es" | "en";
}

const { lang = "es" } = Astro.props;

const i18n = {
  es: {
    title: "Mi día a día en el salón",
    subtitle: "@nafnails_valencia",
  },
  en: {
    title: "My day-to-day at the salon",
    subtitle: "@nafnails_valencia",
  },
};

const t = i18n[lang];
const instagramUrl = "https://www.instagram.com/nafnails_valencia";
---

<section class="bg-nude-50 py-16 px-6 lg:py-24 border-t border-nude-200">
  <div class="max-w-5xl mx-auto flex flex-col items-center">
    <h2 class="text-3xl font-serif text-center text-zinc-800 mb-2">
      {t.title}
    </h2>
    <a
      href={instagramUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="text-pink-600 font-medium hover:text-pink-700 transition-colors mb-12"
    >
      {t.subtitle}
    </a>

    <!-- Elfsight Instagram Feed | Untitled Instagram Feed -->
    <script src="https://elfsightcdn.com/platform.js" async></script>
    <div
      class="elfsight-app-1483e093-b0c9-44b1-a763-690f672554b6"
      data-elfsight-app-lazy
    >
    </div>
  </div>
</section>
