---
// src/pages/index.astro
// Noelia Estética — Rediseño completo · Turia Digital 2026
import Layout from '../layouts/Layout.astro';

const WA_NUM = "34687432500";
const wa = (msg: string) =>
  `https://wa.me/${WA_NUM}?text=${encodeURIComponent(msg)}`;

const IMG = "https://portfolio-noelia-estetica.vercel.app/_astro";

const services = [
  {
    num: "01",
    name: "Microblading & Micropigmentación",
    tag: "Más solicitado",
    desc: "Cejas definidas pelo a pelo con resultado tan natural que será tu secreto. Incluye consulta de forma y tono, sesión y retoque a las 4–6 semanas.",
    detail: "Micropigmentación de labios y eyeliner también disponibles.",
    price: "Desde 120 €",
    duration: "2 – 3 h",
    waMsg: "Hola Noelia, me gustaría información sobre el microblading y reservar una cita.",
    img: `${IMG}/microblading-cejas-antes-despues-1._-Z8ka6N_Z2e4ron.webp`,
  },
  {
    num: "02",
    name: "Manicura & Uñas",
    tag: null,
    desc: "Desde el esmalte semipermanente que dura semanas hasta uñas acrílicas con el diseño que siempre soñaste, sin sacrificar la salud de tu uña natural.",
    detail: "Nail art y diseños personalizados disponibles.",
    price: "Desde 25 €",
    duration: "45 min – 2 h",
    waMsg: "Hola Noelia, me gustaría reservar una cita para manicura.",
    img: `${IMG}/unas-manicura-nude-1.DLU3zJn2_1DRQf9.webp`,
  },
  {
    num: "03",
    name: "Pedicura Spa",
    tag: null,
    desc: "Un ritual completo de relajación: exfoliación, hidratación profunda y esmalte. Sal caminando sobre nubes con unos pies completamente renovados.",
    detail: "Pedicura francesa y diseños especiales disponibles.",
    price: "Desde 30 €",
    duration: "60 – 90 min",
    waMsg: "Hola Noelia, me gustaría reservar una cita para pedicura spa.",
    img: `${IMG}/unas-acrilicas-blancas-1.CA81tXP5_AJoyx.webp`,
  },
];

const steps = [
  { num: "01", title: "Reserva por WhatsApp", desc: "Cuéntame qué buscas. Confirmo tu cita en menos de 24 horas." },
  { num: "02", title: "Consulta personalizada", desc: "Antes de empezar, diseñamos juntas el resultado que quieres conseguir." },
  { num: "03", title: "Tu tratamiento", desc: "En mi estudio privado, sin ruidos ni prisas. Solo tú y tu momento." },
  { num: "04", title: "Resultado que dura", desc: "Saldrás con cuidados por escrito. Escríbeme cualquier duda después." },
];

const gallery = [
  { src: `${IMG}/microblading-cejas-antes-despues-2.CunYCRoY_Z1MiIMM.webp`, alt: "Microblading cejas antes y después", cat: "microblading" },
  { src: `${IMG}/unas-acrilicas-blancas-1.CA81tXP5_AJoyx.webp`,             alt: "Uñas acrílicas blancas",            cat: "unas" },
  { src: `${IMG}/microblading-cejas-antes-despues-3.C47s5Xpm_ZCGsHq.webp`, alt: "Diseño de cejas micropigmentadas",   cat: "microblading" },
  { src: `${IMG}/unas-manicura-divertida.CfLeIgbY_HGzbv.webp`,              alt: "Nail art manicura creativa",         cat: "unas" },
  { src: `${IMG}/microblading-cejas-antes-despues-4.Bp3zdeSF_ZKK2vF.webp`, alt: "Cejas pelo a pelo resultado",        cat: "microblading" },
  { src: `${IMG}/unas-manicura-tematica-1.CqKo3e3U_ep9Ix.webp`,            alt: "Manicura temática francesa",         cat: "unas" },
  { src: `${IMG}/microblading-cejas-antes-despues-5.Cnehf8s-_ZCPs2D.webp`, alt: "Detalle microblading natural",       cat: "microblading" },
  { src: `${IMG}/unas-semipermanente-rojas.ChxAbl2__2mjDP1.webp`,           alt: "Esmalte semipermanente rojo vivo",   cat: "unas" },
  { src: `${IMG}/microblading-cejas-antes-despues-1._-Z8ka6N_Z2e4ron.webp`,alt: "Micropigmentación cejas completa",   cat: "microblading" },
  { src: `${IMG}/unas-acrilicas-blancas-2.ytZELzY2_Z1zVi2z.webp`,          alt: "Uñas acrílicas diseño",             cat: "unas" },
  { src: `${IMG}/unas-manicura-nude-1.DLU3zJn2_1DRQf9.webp`,               alt: "Manicura nude delicada",            cat: "unas" },
  { src: `${IMG}/unas-manicura-tematica-2.BxkZPR5w_ZCHrN8.webp`,           alt: "Manicura original artística",       cat: "unas" },
];

const testimonials = [
  {
    name: "Laura M.",
    service: "Microblading",
    text: "Llevaba años con complejo de mis cejas. Noelia las transformó por completo — el resultado es tan natural que nadie sabe que llevo microblading. 100% recomendable.",
  },
  {
    name: "Sara R.",
    service: "Manicura acrílica",
    text: "Llevo 8 meses yendo con Noelia y no cambiaría. Atenta, profesional y con un ojo para el diseño que no he encontrado en ningún otro sitio en Valencia.",
  },
  {
    name: "Cristina V.",
    service: "Pedicura Spa",
    text: "La pedicura fue una experiencia increíble. Me olvidé del mundo durante hora y media. Mis pies salieron como nuevos. Ya tengo la próxima cita reservada.",
  },
];
---

<Layout>

  <!-- ═══════════════════════════════════════════════════ NAV -->
  <nav id="navbar" class="fixed top-0 inset-x-0 z-50 transition-all duration-300" style="padding: 1.5rem 0;">
    <div class="max-w-6xl mx-auto px-6 flex items-center justify-between">
      <!-- Logo -->
      <a href="#inicio" class="flex flex-col" style="text-decoration:none;">
        <span style="font-family:var(--font-display);font-size:1.35rem;font-weight:400;letter-spacing:0.05em;color:var(--color-dark);line-height:1;">
          Noelia
        </span>
        <span class="section-label" style="letter-spacing:0.2em;">Estética</span>
      </a>

      <!-- Desktop links -->
      <div class="hidden md:flex items-center gap-8">
        <a href="#sobre-mi"    class="nav-link">Sobre mí</a>
        <a href="#servicios"   class="nav-link">Servicios</a>
        <a href="#galeria"     class="nav-link">Galería</a>
        <a href="#contacto"    class="nav-link">Contacto</a>
        <a href={wa("Hola Noelia, me gustaría reservar una cita.")} target="_blank" class="btn-primary" style="padding:0.6rem 1.25rem;font-size:0.75rem;">
          Reservar cita
        </a>
      </div>

      <!-- Mobile burger -->
      <button id="menu-btn" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Abrir menú">
        <span class="menu-bar" style="display:block;width:22px;height:1.5px;background:var(--color-dark);transition:all 0.3s ease;"></span>
        <span class="menu-bar" style="display:block;width:16px;height:1.5px;background:var(--color-dark);transition:all 0.3s ease;"></span>
        <span class="menu-bar" style="display:block;width:22px;height:1.5px;background:var(--color-dark);transition:all 0.3s ease;"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile menu overlay -->
  <div id="mobile-menu" class="mobile-menu">
    <a href="#sobre-mi"  class="mobile-menu-link" data-menu-close>Sobre mí</a>
    <a href="#servicios" class="mobile-menu-link" data-menu-close>Servicios</a>
    <a href="#galeria"   class="mobile-menu-link" data-menu-close>Galería</a>
    <a href="#contacto"  class="mobile-menu-link" data-menu-close>Contacto</a>
    <a href={wa("Hola Noelia, me gustaría reservar una cita.")} target="_blank" class="btn-primary mt-4">
      Reservar cita
    </a>
  </div>

  <!-- ═══════════════════════════════════════════════════ HERO -->
  <section id="inicio" class="min-h-screen grid md:grid-cols-2">
    <!-- Left: text -->
    <div class="flex flex-col justify-center px-8 md:px-16 lg:px-24 pt-32 pb-16 md:pt-0">
      <div class="reveal">
        <span class="section-label">Estética · Patraix · Valencia</span>
        <div class="gold-line mt-3 mb-8"></div>
      </div>

      <h1 class="reveal reveal-delay-1" style="font-family:var(--font-display);font-size:clamp(3rem,6vw,5rem);font-weight:300;line-height:1.1;letter-spacing:-0.01em;margin-bottom:1.75rem;">
        Cejas perfectas.<br/>
        <em style="font-style:italic;font-weight:300;">Uñas impecables.</em><br/>
        Tu momento.
      </h1>

      <p class="reveal reveal-delay-2" style="font-size:1rem;line-height:1.75;color:var(--color-muted);max-width:40ch;margin-bottom:2.5rem;">
        Estudio privado en el corazón de Patraix. Solo cita previa, sin prisas.
        Microblading, manicura y pedicura con resultados que duran semanas.
      </p>

      <div class="reveal reveal-delay-3 flex flex-wrap gap-4">
        <a href={wa("Hola Noelia, me gustaría reservar una cita.")} target="_blank" class="btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.557 4.122 1.533 5.857L.057 23.882l6.198-1.625A11.955 11.955 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.814 9.814 0 01-5.006-1.374l-.36-.213-3.681.965.982-3.594-.234-.369A9.823 9.823 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182c5.43 0 9.818 4.388 9.818 9.818 0 5.43-4.388 9.818-9.818 9.818z"/></svg>
          Reservar cita
        </a>
        <a href="#servicios" class="btn-ghost">Ver servicios</a>
      </div>

      <!-- Social proof tiny -->
      <div class="reveal reveal-delay-4 mt-12 flex items-center gap-4" style="border-top:1px solid var(--color-line);padding-top:1.5rem;">
        <div>
          <div style="font-family:var(--font-display);font-size:2rem;font-weight:400;line-height:1;">★★★★★</div>
          <div style="font-size:0.75rem;color:var(--color-muted);margin-top:0.25rem;">Solo cita previa · Patraix, Valencia</div>
        </div>
        <div style="width:1px;height:2.5rem;background:var(--color-line);"></div>
        <div style="font-size:0.8125rem;color:var(--color-muted);line-height:1.5;">Instagram<br/><a href="https://www.instagram.com/nafnails_valencia" target="_blank" style="color:var(--color-nude-dark);text-decoration:none;font-weight:500;">@nafnails_valencia</a></div>
      </div>
    </div>

    <!-- Right: hero image -->
    <div class="hidden md:block relative" style="background:var(--color-peach);">
      <img
        src={`${IMG}/microblading-cejas-antes-despues-2.CunYCRoY_Z1MiIMM.webp`}
        alt="Resultado microblading cejas en Valencia — Noelia Estética"
        class="w-full h-full object-cover"
        loading="eager"
        style="position:absolute;inset:0;"
      />
      <!-- Subtle overlay -->
      <div style="position:absolute;inset:0;background:linear-gradient(to right,rgba(247,242,234,0.15),transparent);"></div>
      <!-- Corner badge -->
      <div class="reveal reveal-delay-2 absolute bottom-10 left-10" style="background:var(--color-cream);padding:1.25rem 1.5rem;max-width:16rem;">
        <div class="section-label mb-2">Resultado real</div>
        <p style="font-family:var(--font-display);font-size:1.1rem;font-weight:400;line-height:1.3;color:var(--color-dark);">Microblading pelo a pelo. Sin filtros.</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ SOBRE MÍ -->
  <section id="sobre-mi" style="padding:7rem 0;background:var(--color-light);">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
      <!-- Image -->
      <div class="reveal img-hover relative order-2 md:order-1">
        <img
          src={`${IMG}/unas-manicura-nude-1.DLU3zJn2_1DRQf9.webp`}
          alt="Noelia trabajando en su estudio de Patraix"
          class="w-full"
          style="aspect-ratio:4/5;object-fit:cover;"
          loading="lazy"
        />
        <!-- Decorative border offset -->
        <div style="position:absolute;inset:-12px;border:1px solid var(--color-nude);z-index:-1;pointer-events:none;"></div>
      </div>

      <!-- Text -->
      <div class="order-1 md:order-2">
        <div class="reveal">
          <span class="section-label">Sobre mí</span>
          <div class="gold-line mt-3 mb-8"></div>
        </div>

        <h2 class="reveal reveal-delay-1" style="font-family:var(--font-display);font-size:clamp(2.25rem,4vw,3.25rem);font-weight:300;line-height:1.15;margin-bottom:1.75rem;">
          Soy Noelia.<br/>
          <em>Tu espacio de<br/>belleza en Patraix.</em>
        </h2>

        <p class="reveal reveal-delay-2" style="font-size:0.9375rem;line-height:1.85;color:var(--color-muted);margin-bottom:1.25rem;">
          Llevo años ayudando a mujeres de Valencia a sentirse bien con su piel, sus cejas y sus manos.
          Mi estudio en Patraix es un espacio solo para ti: privado, tranquilo, sin prisas.
        </p>
        <p class="reveal reveal-delay-3" style="font-size:0.9375rem;line-height:1.85;color:var(--color-muted);margin-bottom:2.5rem;">
          Trabajo exclusivamente con cita previa porque cada cliente se merece mi atención completa.
          Solo necesitas venir con ganas de mimarte. Yo me encargo del resto.
        </p>

        <!-- Stats -->
        <div class="reveal reveal-delay-4 grid grid-cols-3 gap-6 mb-8" style="border-top:1px solid var(--color-line);padding-top:2rem;">
          <div>
            <div style="font-family:var(--font-display);font-size:2.5rem;font-weight:400;line-height:1;color:var(--color-nude-dark);">5+</div>
            <div style="font-size:0.75rem;color:var(--color-muted);margin-top:0.25rem;letter-spacing:0.05em;">Años de<br/>experiencia</div>
          </div>
          <div>
            <div style="font-family:var(--font-display);font-size:2.5rem;font-weight:400;line-height:1;color:var(--color-nude-dark);">300+</div>
            <div style="font-size:0.75rem;color:var(--color-muted);margin-top:0.25rem;letter-spacing:0.05em;">Clientes<br/>satisfechas</div>
          </div>
          <div>
            <div style="font-family:var(--font-display);font-size:2.5rem;font-weight:400;line-height:1;color:var(--color-nude-dark);">★ 5.0</div>
            <div style="font-size:0.75rem;color:var(--color-muted);margin-top:0.25rem;letter-spacing:0.05em;">Valoración<br/>media</div>
          </div>
        </div>

        <div class="reveal reveal-delay-5">
          <a href={wa("Hola Noelia, me gustaría conocer más sobre tus servicios.")} target="_blank" class="btn-ghost">
            Escríbeme →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ SERVICIOS -->
  <section id="servicios" style="padding:7rem 0;">
    <div class="max-w-6xl mx-auto px-6">
      <div class="reveal text-center mb-16">
        <span class="section-label">Servicios</span>
        <div class="gold-line mx-auto mt-3 mb-6"></div>
        <h2 style="font-family:var(--font-display);font-size:clamp(2rem,4vw,3rem);font-weight:300;line-height:1.2;">
          Experiencias de belleza<br/><em>que transforman</em>
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {services.map((s, i) => (
          <div class={`service-card reveal reveal-delay-${i + 1}`}>
            <!-- Number + tag -->
            <div class="flex items-start justify-between mb-6">
              <span style="font-family:var(--font-display);font-size:3.5rem;font-weight:300;line-height:1;color:var(--color-line);">{s.num}</span>
              {s.tag && (
                <span style="font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;background:var(--color-peach);color:var(--color-nude-dark);padding:0.25rem 0.625rem;font-weight:500;">
                  {s.tag}
                </span>
              )}
            </div>

            <!-- Image -->
            <div class="img-hover mb-6" style="aspect-ratio:4/3;overflow:hidden;">
              <img src={s.img} alt={s.name} class="w-full h-full object-cover" loading="lazy" />
            </div>

            <!-- Content -->
            <h3 style="font-family:var(--font-display);font-size:1.375rem;font-weight:400;margin-bottom:0.75rem;line-height:1.3;">{s.name}</h3>
            <p style="font-size:0.875rem;line-height:1.75;color:var(--color-muted);margin-bottom:0.5rem;">{s.desc}</p>
            <p style="font-size:0.8rem;color:var(--color-nude-dark);margin-bottom:1.5rem;font-style:italic;">{s.detail}</p>

            <!-- Price + duration -->
            <div class="flex items-center justify-between mb-6" style="padding:0.875rem 0;border-top:1px solid var(--color-line);border-bottom:1px solid var(--color-line);">
              <div>
                <div style="font-family:var(--font-display);font-size:1.5rem;font-weight:500;">{s.price}</div>
                <div style="font-size:0.7rem;color:var(--color-muted);letter-spacing:0.08em;text-transform:uppercase;margin-top:0.1rem;">Precio orientativo</div>
              </div>
              <div style="text-align:right;">
                <div style="font-size:0.875rem;font-weight:500;color:var(--color-dark);">{s.duration}</div>
                <div style="font-size:0.7rem;color:var(--color-muted);letter-spacing:0.08em;text-transform:uppercase;margin-top:0.1rem;">Duración</div>
              </div>
            </div>

            <a href={wa(s.waMsg)} target="_blank" class="btn-primary w-full justify-center" style="width:100%;">
              Reservar →
            </a>
          </div>
        ))}
      </div>

      <!-- Extra services note -->
      <div class="reveal mt-10 text-center" style="padding:1.5rem;border:1px solid var(--color-line);">
        <p style="font-size:0.875rem;color:var(--color-muted);">
          ¿Buscas algo diferente? Escríbeme y buscamos la opción perfecta para ti.
          <a href={wa("Hola Noelia, tengo una consulta sobre tus servicios.")} target="_blank" style="color:var(--color-nude-dark);text-decoration:none;font-weight:500;margin-left:0.25rem;">Consultar →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ PROCESO -->
  <section style="padding:7rem 0;background:var(--color-dark);">
    <div class="max-w-6xl mx-auto px-6">
      <div class="reveal text-center mb-16">
        <span class="section-label" style="color:var(--color-nude);">Cómo funciona</span>
        <div class="gold-line mx-auto mt-3 mb-6"></div>
        <h2 style="font-family:var(--font-display);font-size:clamp(2rem,4vw,3rem);font-weight:300;line-height:1.2;color:var(--color-cream);">
          Tu cita, paso a paso
        </h2>
      </div>

      <div class="flex flex-col md:flex-row items-start md:items-start gap-0">
        {steps.map((step, i) => (
          <div class="flex flex-col md:flex-col flex-1" style="position:relative;">
            <!-- Connecting line on desktop -->
            {i < steps.length - 1 && (
              <div class="hidden md:block" style="position:absolute;top:2rem;left:calc(50% + 2rem);width:calc(100% - 4rem);height:1px;background:rgba(201,168,130,0.25);"></div>
            )}

            <div class={`reveal reveal-delay-${i + 1} flex flex-row md:flex-col gap-6 md:gap-0 items-start md:items-center pb-10 md:pb-0`}>
              <!-- Number circle -->
              <div style="width:4rem;height:4rem;border:1px solid var(--color-nude);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-bottom:0;margin-right:0;">
                <span style="font-family:var(--font-display);font-size:1.125rem;font-weight:400;color:var(--color-nude);letter-spacing:0.05em;">{step.num}</span>
              </div>

              <div class="md:text-center" style="padding-top:0.25rem;flex:1;">
                <div class="hidden md:block" style="height:2.5rem;"></div>
                <h3 style="font-family:var(--font-display);font-size:1.25rem;font-weight:400;color:var(--color-cream);margin-bottom:0.625rem;line-height:1.3;">{step.title}</h3>
                <p style="font-size:0.875rem;line-height:1.75;color:rgba(247,242,234,0.55);">{step.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="reveal mt-16 text-center">
        <a href={wa("Hola Noelia, me gustaría reservar una cita.")} target="_blank" class="btn-primary" style="background:var(--color-nude);color:var(--color-dark);">
          Empezar ahora →
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ TESTIMONIOS -->
  <section style="padding:7rem 0;background:var(--color-light);">
    <div class="max-w-6xl mx-auto px-6">
      <div class="reveal text-center mb-16">
        <span class="section-label">Testimonios</span>
        <div class="gold-line mx-auto mt-3 mb-6"></div>
        <h2 style="font-family:var(--font-display);font-size:clamp(2rem,4vw,3rem);font-weight:300;line-height:1.2;">
          Lo que dicen<br/><em>mis clientas</em>
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {testimonials.map((t, i) => (
          <div class={`testimonial-card reveal reveal-delay-${i + 1}`}>
            <div class="stars mb-4" style="font-size:0.9rem;">★★★★★</div>
