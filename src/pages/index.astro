<!-- ═══════════════════════════════════════════════════════ SCRIPTS -->
<script>
  // ── Sticky nav background
  const navbar = document.getElementById('navbar') as HTMLElement;
  const onScroll = () => {
    if (window.scrollY > 80) {
      navbar.style.background = 'rgba(247,242,234,0.95)';
      navbar.style.backdropFilter = 'blur(12px)';
      navbar.style.boxShadow = '0 1px 0 rgba(201,168,130,0.2)';
      navbar.style.padding = '1rem 0';
    } else {
      navbar.style.background = 'transparent';
      navbar.style.backdropFilter = '';
      navbar.style.boxShadow = '';
      navbar.style.padding = '1.5rem 0';
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // ── Mobile menu
  const menuBtn  = document.getElementById('menu-btn')  as HTMLButtonElement;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;
  const bars = document.querySelectorAll('.menu-bar') as NodeListOf<HTMLElement>;

  let menuOpen = false;
  menuBtn.addEventListener('click', () => {
    menuOpen = !menuOpen;
    mobileMenu.classList.toggle('open', menuOpen);
    document.body.style.overflow = menuOpen ? 'hidden' : '';
    // Animate bars
    if (menuOpen) {
      bars[0].style.transform = 'translateY(7.5px) rotate(45deg)';
      bars[1].style.opacity = '0';
      bars[2].style.transform = 'translateY(-7.5px) rotate(-45deg)';
      bars[2].style.width = '22px';
    } else {
      bars[0].style.transform = '';
      bars[1].style.opacity = '';
      bars[2].style.transform = '';
      bars[2].style.width = '';
    }
  });

  document.querySelectorAll('[data-menu-close]').forEach(el => {
    el.addEventListener('click', () => {
      menuOpen = false;
      mobileMenu.classList.remove('open');
      document.body.style.overflow = '';
      bars[0].style.transform = '';
      bars[1].style.opacity = '';
      bars[2].style.transform = '';
      bars[2].style.width = '';
    });
  });

  // ── Scroll reveal
  const revealEls = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  );
  revealEls.forEach(el => io.observe(el));

  // ── Gallery filter
  const filterBtns = document.querySelectorAll('.filter-btn') as NodeListOf<HTMLButtonElement>;
  const galleryItems = document.querySelectorAll('.gallery-item') as NodeListOf<HTMLElement>;

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter as string;

      // Update active button
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      // Filter items
      galleryItems.forEach(item => {
        const cat = item.dataset.cat as string;
        const show = filter === 'all' || cat === filter;

        if (!show) {
          item.classList.add('fading');
          setTimeout(() => {
            if (item.classList.contains('fading')) {
              item.style.display = 'none';
            }
          }, 320);
        } else {
          item.style.display = '';
          item.classList.remove('fading');
        }
      });
    });
  });
</script>

